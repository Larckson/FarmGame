<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="FarmGame" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/FarmGame" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/FarmGame" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-pedantic-errors" />
			<Add option="-Wall" />
			<Add option="-std=c89 -pedantic-errors" />
		</Compiler>
		<Linker>
			<Add library="gdi32" />
			<Add library="user32" />
			<Add library="obj/Debug/utils.obj" />
		</Linker>
		<Unit filename="src/adjustfarmsetup.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/charbitmap.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/gfx.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/gfxlinux.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/gfxwindows.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/initfarmsetup.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/main.c">
			<Option compilerVar="CC" />
			<Option link="0" />
			<Option weight="60" />
			<Option compiler="gcc" use="1" buildCommand='wsl bash -c &quot;gcc -c $(wslpath -u \&quot;$file\&quot;) -o $(wslpath -u \&quot;$object\&quot;)&quot;\n' />
		</Unit>
		<Unit filename="src/pack.c">
			<Option compilerVar="CC" />
			<Option compile="0" />
			<Option link="0" />
		</Unit>
		<Unit filename="src/utils.asm">
			<Option compilerVar="CC" />
			<Option link="0" />
			<Option compiler="gcc" use="1" buildCommand='nasm -f win64 &quot;$file&quot; -o obj\Debug\utils.obj' />
		</Unit>
		<Unit filename="src/utilslinux.asm">
			<Option compilerVar="CC" />
			<Option link="0" />
			<Option compiler="gcc" use="1" buildCommand='nasm -f win64 &quot;$file&quot; -o obj\Debug\utilslinux.obj' />
		</Unit>
		<Unit filename="src/utilswindows.asm">
			<Option compilerVar="CC" />
			<Option link="0" />
